{
  "name": "fallow-knip",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "analyze:knip": "pnpm --dir sample-codebase exec knip",
    "analyze:fallow": "pnpm --dir sample-codebase exec fallow --summary",
    "analyze:fallow:dead-code": "pnpm --dir sample-codebase exec fallow dead-code",
    "analyze:fallow:dupes": "pnpm --dir sample-codebase exec fallow dupes",
    "analyze:fallow:health": "pnpm --dir sample-codebase exec fallow health --hotspots",
    "analyze:fallow:fix": "pnpm --dir sample-codebase exec fallow fix --dry-run",
    "benchmark": "tsx scripts/benchmark.ts",
    "capture-outputs": "tsx scripts/capture-cli-outputs.ts"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fallow": "^2.84.0",
    "globals": "^17.6.0",
    "knip": "^6.14.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
